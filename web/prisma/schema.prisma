// Prisma schema for RestaurantSplit (SQLite)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth models
model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  // Relations
  accounts      Account[]
  sessions      Session[]
  // App-owned rows (optional scoping for now)
  bills         Bill[]    @relation("UserBills")
  contacts      Contact[] @relation("UserContacts")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum TaxMode {
  GLOBAL
  ITEM
}

model Contact {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  phone        String?
  venmo        String?
  cashapp      String?
  createdAt    DateTime @default(now())
  isTemporary  Boolean  @default(false)
  participants BillParticipant[]
  paidBills    Bill[] @relation("BillPaidBy")
  userId       String?
  user         User?   @relation("UserContacts", fields: [userId], references: [id])
}

model Bill {
  id             String   @id @default(cuid())
  title          String
  venue          String?
  date           DateTime @default(now())
  subtotalCents  Int
  taxRatePct     Float    @default(0)
  tipRatePct     Float    @default(0)
  convenienceFeeRatePct Float @default(0)
  currency       String   @default("USD")
  taxMode        TaxMode  @default(GLOBAL)
  createdAt      DateTime @default(now())
  participants   BillParticipant[]
  items          Item[]
  paidByContactId String?
  paidBy          Contact? @relation("BillPaidBy", fields: [paidByContactId], references: [id])
  userId         String?
  user           User? @relation("UserBills", fields: [userId], references: [id])
}

model BillParticipant {
  id         String  @id @default(cuid())
  billId     String
  contactId  String
  note       String?
  bill       Bill    @relation(fields: [billId], references: [id])
  contact    Contact @relation(fields: [contactId], references: [id])
  shares     ItemShare[]
}

model Item {
  id         String @id @default(cuid())
  billId     String
  name       String
  priceCents Int
  quantity   Int    @default(1)
  taxable    Boolean @default(true)
  taxRatePct Float   @default(0)
  bill       Bill   @relation(fields: [billId], references: [id])
  shares     ItemShare[]
}

model ItemShare {
  id             String @id @default(cuid())
  itemId         String
  participantId  String
  weight         Float  @default(1)
  item           Item   @relation(fields: [itemId], references: [id])
  participant    BillParticipant @relation(fields: [participantId], references: [id])

  @@unique([itemId, participantId])
}


