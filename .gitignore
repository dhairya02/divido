# Monorepo gitignore

# Node modules
node_modules/

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Build outputs
dist/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# iOS specific
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/
ios/*.xcworkspace/xcuserdata/
ios/DerivedData/
ios/build/
ios/.build/
ios/.swiftpm/
ios/*.ipa
ios/*.dSYM.zip
ios/*.dSYM

# Web app specific - defer to web/.gitignore

